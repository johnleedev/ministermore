{
  "name": "ministermore",
  "version": "1.4",
  "private": true,
  "scripts": {
    "all": "cd ios && pod install && cd .. && npm run android",
    "android": "react-native run-android --no-packager",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "androidclean": "cd android && ./gradlew clean && cd ..",
    "iosclean": "cd ios && rm -rf Pods ios/Podfile.lock && pod install && cd ..",
    "iosreset": "cd ios && rm -rf Pods build Podfile.lock && pod cache clean --all && pod install && cd .."
  },
